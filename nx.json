{
  "$schema": "https://nx.dev/reference/nx-json",
  "plugins": [
    {
      "plugin": "@nx/js/typescript",
      "options": {
        "typecheck": {
          "targetName": "typecheck"
        },
        "build": {
          "targetName": "build"
        }
      }
    },
    {
      "plugin": "@nx/eslint/plugin",
      "options": {
        "targetName": "lint"
      }
    }
  ],
  "targetDefaults": {
    "nx-release-publish": {
      "options": {
        "access": "public"
      }
    },
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "production",
        "^production"
      ],
      "outputs": [
        "{projectRoot}/dist"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "production",
        "^production"
      ]
    },
    "test": {
      "dependsOn": [
        "build"
      ],
      "inputs": [
        "default",
        "^production"
      ]
    },
    "lint": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "default",
        "^production"
      ]
    }
  },
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "production": [
      "default",
      "!{projectRoot}/**/*.test.ts",
      "!{projectRoot}/**/*.spec.ts",
      "!{projectRoot}/tsconfig.spec.json"
    ],
    "sharedGlobals": [
      "{workspaceRoot}/tsconfig.base.json"
    ]
  },
  "defaultBase": "main",
  "release": {
    "projects": ["packages/*", "!packages/docs", "!packages/example-*"],
    "version": {
      "conventionalCommits": true,
      "git": {
        "commit": true,
        "commitMessage": "chore(release): {version} [skip ci]",
        "tag": true
      }
    },
    "changelog": {
      "workspaceChangelog": {
        "createRelease": "github",
        "file": false
      },
      "git": {
        "commit": false,
        "tag": false
      }
    }
  }
}
