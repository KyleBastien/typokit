{
  "name": "@typokit/monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "description": "TypoKit — AI-Native Node.js Framework",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "nx run-many --target=build",
    "test": "nx run-many --target=test",
    "lint": "nx run-many --target=lint",
    "typecheck": "nx run-many --target=typecheck",
    "affected:build": "nx affected -t build",
    "affected:test": "nx affected -t test",
    "affected:lint": "nx affected -t lint",
    "affected:typecheck": "nx affected -t typecheck",
    "bench": "nx run benchmarks:bench",
    "bench:ci": "nx run benchmarks:bench-ci",
    "bench:baseline": "nx run benchmarks:bench-baseline",
    "bench:info": "nx run benchmarks:bench-info",
    "bench:reproduce": "nx run benchmarks:bench-reproduce"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@napi-rs/cli": "^3.5.1",
    "@nx/eslint": "22.5.4",
    "@nx/js": "22.5.4",
    "@rstest/core": "^0.0.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "nx": "22.5.4",
    "prettier": "^3.8.1",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0"
  }
}
