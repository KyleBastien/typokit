---
/**
 * BenchmarkCharts.astro — Build-time chart rendering for benchmark results.
 * Imports latest.json from the benchmarks package and renders Chart.js charts
 * via client-side <script> initialization on <canvas> elements.
 */

// At build time, try to load latest.json; fall back to sample data if not available.
import { readFileSync, existsSync } from "node:fs";
import { resolve, dirname } from "node:path";
import { fileURLToPath } from "node:url";

interface LatencyPercentiles {
  p50: number;
  p75: number;
  p90: number;
  p95: number;
  p99: number;
}

interface BenchmarkResult {
  framework: string;
  platform: string;
  server: string;
  scenario: string;
  reqPerSec: number;
  latency: LatencyPercentiles;
  errors: number;
}

interface ResultsFile {
  version: number;
  results: BenchmarkResult[];
}

// Resolve path to benchmarks results
const __dirname = dirname(fileURLToPath(import.meta.url));
const resultsPath = resolve(
  __dirname,
  "../../../../benchmarks/results/latest.json"
);

let resultsData: ResultsFile;
if (existsSync(resultsPath)) {
  resultsData = JSON.parse(readFileSync(resultsPath, "utf-8"));
  // Handle legacy raw arrays
  if (Array.isArray(resultsData)) {
    resultsData = { version: 1, results: resultsData as unknown as BenchmarkResult[] };
  }
} else {
  // Sample data for docs builds before benchmarks have been run
  resultsData = generateSampleData();
}

function generateSampleData(): ResultsFile {
  const typoKitCombos = [
    { platform: "node", server: "native" },
    { platform: "node", server: "fastify" },
    { platform: "node", server: "hono" },
    { platform: "node", server: "express" },
    { platform: "bun", server: "native" },
    { platform: "bun", server: "fastify" },
    { platform: "bun", server: "hono" },
    { platform: "bun", server: "express" },
    { platform: "deno", server: "native" },
    { platform: "deno", server: "fastify" },
    { platform: "deno", server: "hono" },
    { platform: "deno", server: "express" },
    { platform: "rust", server: "axum" },
  ];

  const rawApps = [
    { framework: "raw", platform: "node", server: "http" },
    { framework: "raw", platform: "bun", server: "bun-serve" },
    { framework: "raw", platform: "deno", server: "deno-serve" },
    { framework: "raw", platform: "rust", server: "axum" },
  ];

  const competitors = [
    { framework: "express", platform: "node", server: "standalone" },
    { framework: "fastify", platform: "node", server: "standalone" },
    { framework: "hono", platform: "node", server: "standalone" },
    { framework: "koa", platform: "node", server: "standalone" },
    { framework: "elysia", platform: "bun", server: "standalone" },
    { framework: "trpc", platform: "node", server: "standalone" },
    { framework: "nestjs", platform: "node", server: "standalone" },
    { framework: "h3", platform: "node", server: "standalone" },
    { framework: "adonis", platform: "node", server: "standalone" },
  ];

  const scenarios = ["json", "validate", "db", "middleware", "startup"];

  // Realistic-ish sample throughput values (req/s) per scenario
  const baseThroughput: Record<string, Record<string, number>> = {
    json: {
      "typokit-rust-axum": 320000,
      "typokit-bun-native": 185000,
      "typokit-bun-hono": 170000,
      "typokit-bun-fastify": 155000,
      "typokit-bun-express": 95000,
      "typokit-deno-native": 145000,
      "typokit-deno-hono": 140000,
      "typokit-deno-fastify": 130000,
      "typokit-deno-express": 80000,
      "typokit-node-native": 125000,
      "typokit-node-hono": 115000,
      "typokit-node-fastify": 110000,
      "typokit-node-express": 55000,
      "raw-rust-axum": 350000,
      "raw-bun-bun-serve": 200000,
      "raw-deno-deno-serve": 160000,
      "raw-node-http": 135000,
      "express-node-standalone": 38000,
      "fastify-node-standalone": 95000,
      "hono-node-standalone": 105000,
      "koa-node-standalone": 45000,
      "elysia-bun-standalone": 175000,
      "trpc-node-standalone": 60000,
      "nestjs-node-standalone": 35000,
      "h3-node-standalone": 85000,
      "adonis-node-standalone": 30000,
    },
  };

  const results: BenchmarkResult[] = [];
  const latency = (rps: number): LatencyPercentiles => ({
    p50: Math.round((1000 / rps) * 1e6 * 50) / 100,
    p75: Math.round((1000 / rps) * 1e6 * 75) / 100,
    p90: Math.round((1000 / rps) * 1e6 * 120) / 100,
    p95: Math.round((1000 / rps) * 1e6 * 180) / 100,
    p99: Math.round((1000 / rps) * 1e6 * 400) / 100,
  });

  for (const scenario of scenarios) {
    // TypoKit combos
    for (const combo of typoKitCombos) {
      const key = `typokit-${combo.platform}-${combo.server}`;
      const jsonRps = baseThroughput.json[key] ?? 80000;
      const factor = scenario === "json" ? 1.0
        : scenario === "validate" ? 0.85
        : scenario === "db" ? 0.4
        : scenario === "middleware" ? 0.95
        : 0.001; // startup → treated as ms not rps
      const rps = scenario === "startup"
        ? Math.round(50 + Math.random() * 150)
        : Math.round(jsonRps * factor);
      results.push({
        framework: `typokit-${combo.platform}-${combo.server}`,
        platform: combo.platform,
        server: combo.server,
        scenario,
        reqPerSec: rps,
        latency: latency(scenario === "startup" ? 100000 : rps),
        errors: 0,
      });
    }
    // Raw baselines
    for (const raw of rawApps) {
      const key = `${raw.framework}-${raw.platform}-${raw.server}`;
      const jsonRps = baseThroughput.json[key] ?? 120000;
      const factor = scenario === "json" ? 1.0
        : scenario === "validate" ? 0.9
        : scenario === "db" ? 0.45
        : scenario === "middleware" ? 0.98
        : 0.001;
      const rps = scenario === "startup"
        ? Math.round(30 + Math.random() * 100)
        : Math.round(jsonRps * factor);
      results.push({
        framework: `raw-${raw.platform}`,
        platform: raw.platform,
        server: raw.server,
        scenario,
        reqPerSec: rps,
        latency: latency(scenario === "startup" ? 100000 : rps),
        errors: 0,
      });
    }
    // Competitors
    for (const comp of competitors) {
      const key = `${comp.framework}-${comp.platform}-${comp.server}`;
      const jsonRps = baseThroughput.json[key] ?? 50000;
      const factor = scenario === "json" ? 1.0
        : scenario === "validate" ? 0.8
        : scenario === "db" ? 0.35
        : scenario === "middleware" ? 0.9
        : 0.001;
      const rps = scenario === "startup"
        ? Math.round(100 + Math.random() * 300)
        : Math.round(jsonRps * factor);
      results.push({
        framework: comp.framework,
        platform: comp.platform,
        server: comp.server,
        scenario,
        reqPerSec: rps,
        latency: latency(scenario === "startup" ? 100000 : rps),
        errors: 0,
      });
    }
  }

  return { version: 1, results };
}

// Group results by scenario
const resultsByScenario: Record<string, BenchmarkResult[]> = {};
for (const r of resultsData.results) {
  if (!resultsByScenario[r.scenario]) resultsByScenario[r.scenario] = [];
  resultsByScenario[r.scenario].push(r);
}

// Sort each scenario group by reqPerSec descending
for (const key of Object.keys(resultsByScenario)) {
  resultsByScenario[key].sort((a, b) => b.reqPerSec - a.reqPerSec);
}

// Build heatmap data for TypoKit combos
const typokitResults = resultsData.results.filter((r) =>
  r.framework.startsWith("typokit-")
);
const platforms = ["node", "bun", "deno", "rust"];
const servers = ["native", "fastify", "hono", "express", "axum"];
const heatmapData: { platform: string; server: string; rps: number | null }[] = [];
for (const platform of platforms) {
  for (const server of servers) {
    const match = typokitResults.find(
      (r) => r.platform === platform && r.server === server && r.scenario === "json"
    );
    heatmapData.push({
      platform,
      server,
      rps: match ? match.reqPerSec : null,
    });
  }
}

// Top latency entries for the table (json scenario, top 15)
const latencyEntries = (resultsByScenario["json"] ?? []).slice(0, 15);

// Serialize data for client-side scripts
const chartData = JSON.stringify({
  json: (resultsByScenario["json"] ?? []).map((r) => ({
    label: r.framework,
    rps: r.reqPerSec,
  })),
  validate: (resultsByScenario["validate"] ?? []).map((r) => ({
    label: r.framework,
    rps: r.reqPerSec,
  })),
  db: (resultsByScenario["db"] ?? []).map((r) => ({
    label: r.framework,
    rps: r.reqPerSec,
  })),
  startup: (resultsByScenario["startup"] ?? []).map((r) => ({
    label: r.framework,
    rps: r.reqPerSec,
  })),
});

// Color assignments
function getColor(label: string): string {
  if (label.startsWith("typokit-") && label.includes("rust")) return "#e8590c";
  if (label.startsWith("typokit-")) return "#7c3aed";
  if (label.startsWith("raw-")) return "#6b7280";
  // Competitors
  const colors: Record<string, string> = {
    express: "#f59e0b",
    fastify: "#10b981",
    hono: "#f97316",
    koa: "#06b6d4",
    elysia: "#ec4899",
    trpc: "#3b82f6",
    nestjs: "#ef4444",
    h3: "#8b5cf6",
    adonis: "#14b8a6",
  };
  for (const [key, color] of Object.entries(colors)) {
    if (label.includes(key)) return color;
  }
  return "#9ca3af";
}

const colorMap = JSON.stringify(
  Object.fromEntries(
    resultsData.results
      .map((r) => r.framework)
      .filter((v, i, arr) => arr.indexOf(v) === i)
      .map((f) => [f, getColor(f)])
  )
);

const isSampleData = !existsSync(resultsPath);
---

<div class="benchmark-charts">
  {isSampleData && (
    <aside class="sample-data-notice">
      <p>
        <strong>📊 Sample Data</strong> — These charts show representative sample
        data. Run <code>pnpm nx bench benchmarks</code> to generate real results.
      </p>
    </aside>
  )}

  <!-- JSON Scenario -->
  <section class="chart-section">
    <h3 id="json-throughput">JSON Serialization — Requests/sec</h3>
    <p class="chart-caption">Logarithmic scale. Higher is better.</p>
    <div class="chart-container">
      <canvas id="chart-json"></canvas>
    </div>
  </section>

  <!-- Validate Scenario -->
  <section class="chart-section">
    <h3 id="validate-throughput">Validation — Requests/sec</h3>
    <p class="chart-caption">
      Logarithmic scale. Includes request body parsing and validation.
    </p>
    <div class="chart-container">
      <canvas id="chart-validate"></canvas>
    </div>
  </section>

  <!-- DB Scenario -->
  <section class="chart-section">
    <h3 id="db-throughput">Database (SQLite) — Requests/sec</h3>
    <p class="chart-caption">
      Logarithmic scale. Full request lifecycle including SQLite read.
    </p>
    <div class="chart-container">
      <canvas id="chart-db"></canvas>
    </div>
  </section>

  <!-- Startup Scenario -->
  <section class="chart-section">
    <h3 id="startup-times">Cold Start Times (ms)</h3>
    <p class="chart-caption">
      Linear scale. Lower is better. Time from process start to first response.
    </p>
    <div class="chart-container">
      <canvas id="chart-startup"></canvas>
    </div>
  </section>

  <!-- Heatmap -->
  <section class="chart-section">
    <h3 id="platform-heatmap">TypoKit Platform × Server Heatmap</h3>
    <p class="chart-caption">
      JSON scenario req/s across all 13 TypoKit combinations. Rust/Axum shown in
      orange.
    </p>
    <div class="heatmap-grid">
      <div class="heatmap-header heatmap-cell"></div>
      {servers.map((s) => (
        <div class="heatmap-header heatmap-cell">{s}</div>
      ))}
      {platforms.map((p) => (
        <>
          <div class="heatmap-row-label heatmap-cell">{p}</div>
          {servers.map((s) => {
            const entry = heatmapData.find(
              (h) => h.platform === p && h.server === s
            );
            const rps = entry?.rps;
            const maxRps = Math.max(
              ...heatmapData.filter((h) => h.rps !== null).map((h) => h.rps!)
            );
            const intensity = rps != null ? rps / maxRps : 0;
            const isRust = p === "rust";
            const bgColor =
              rps == null
                ? "var(--sl-color-gray-6)"
                : isRust
                  ? `rgba(232, 89, 12, ${0.2 + intensity * 0.8})`
                  : `rgba(124, 58, 237, ${0.2 + intensity * 0.8})`;
            const textColor = rps == null ? "var(--sl-color-gray-3)" : intensity > 0.5 ? "#fff" : "var(--sl-color-white)";
            return (
              <div
                class="heatmap-cell heatmap-value"
                style={`background:${bgColor};color:${textColor};`}
              >
                {rps != null ? `${Math.round(rps / 1000)}k` : "—"}
              </div>
            );
          })}
        </>
      ))}
    </div>
  </section>

  <!-- Latency Table -->
  <section class="chart-section">
    <h3 id="latency-percentiles">Latency Percentiles (JSON Scenario)</h3>
    <p class="chart-caption">
      All values in milliseconds. Lower is better.
    </p>
    <div class="latency-table-wrapper">
      <table class="latency-table">
        <thead>
          <tr>
            <th>Rank</th>
            <th>Framework</th>
            <th>req/s</th>
            <th>p50</th>
            <th>p75</th>
            <th>p90</th>
            <th>p95</th>
            <th>p99</th>
          </tr>
        </thead>
        <tbody>
          {latencyEntries.map((r, i) => (
            <tr class={r.framework.startsWith("typokit-") ? "typokit-row" : ""}>
              <td>{i + 1}</td>
              <td>
                <span class="fw-badge" style={`background:${getColor(r.framework)};`}></span>
                {r.framework}
              </td>
              <td>{r.reqPerSec.toLocaleString("en-US")}</td>
              <td>{r.latency.p50.toFixed(2)}</td>
              <td>{r.latency.p75.toFixed(2)}</td>
              <td>{r.latency.p90.toFixed(2)}</td>
              <td>{r.latency.p95.toFixed(2)}</td>
              <td>{r.latency.p99.toFixed(2)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</div>

<style>
  .benchmark-charts {
    max-width: 100%;
    overflow: hidden;
  }

  .sample-data-notice {
    background: var(--sl-color-blue-low);
    border: 1px solid var(--sl-color-blue);
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    margin-bottom: 1.5rem;
  }

  .sample-data-notice p {
    margin: 0;
    font-size: 0.9rem;
  }

  .chart-section {
    margin-bottom: 2.5rem;
  }

  .chart-section h3 {
    margin-bottom: 0.25rem;
  }

  .chart-caption {
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
    margin-top: 0;
    margin-bottom: 0.75rem;
  }

  .chart-container {
    position: relative;
    width: 100%;
    max-height: 500px;
  }

  .chart-container canvas {
    width: 100% !important;
    max-height: 500px;
  }

  /* Heatmap */
  .heatmap-grid {
    display: grid;
    grid-template-columns: auto repeat(5, 1fr);
    gap: 2px;
    max-width: 600px;
  }

  .heatmap-cell {
    padding: 0.5rem 0.75rem;
    text-align: center;
    font-size: 0.85rem;
    border-radius: 4px;
  }

  .heatmap-header {
    font-weight: 600;
    text-transform: capitalize;
  }

  .heatmap-row-label {
    font-weight: 600;
    text-transform: capitalize;
    text-align: right;
  }

  .heatmap-value {
    font-variant-numeric: tabular-nums;
  }

  /* Latency table */
  .latency-table-wrapper {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .latency-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
    font-variant-numeric: tabular-nums;
  }

  .latency-table th,
  .latency-table td {
    padding: 0.4rem 0.6rem;
    text-align: right;
    border-bottom: 1px solid var(--sl-color-gray-5);
    white-space: nowrap;
  }

  .latency-table th {
    font-weight: 600;
    border-bottom: 2px solid var(--sl-color-gray-4);
  }

  .latency-table td:nth-child(2) {
    text-align: left;
  }

  .latency-table th:nth-child(2) {
    text-align: left;
  }

  .typokit-row {
    background: rgba(124, 58, 237, 0.08);
  }

  .fw-badge {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 2px;
    margin-right: 0.4rem;
    vertical-align: middle;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .heatmap-grid {
      font-size: 0.75rem;
    }
    .heatmap-cell {
      padding: 0.3rem 0.4rem;
    }
    .chart-container {
      max-height: 350px;
    }
    .latency-table {
      font-size: 0.75rem;
    }
  }
</style>

<script define:vars={{ chartData, colorMap }}>
  // Chart.js is loaded via CDN in the page head
  const data = JSON.parse(chartData);
  const colors = JSON.parse(colorMap);

  function createBarChart(canvasId, items, options = {}) {
    const canvas = document.getElementById(canvasId);
    if (!canvas) return;

    const labels = items.map((d) => d.label);
    const values = items.map((d) => d.rps);
    const bgColors = labels.map((l) => colors[l] || "#9ca3af");

    new Chart(canvas, {
      type: "bar",
      data: {
        labels,
        datasets: [
          {
            data: values,
            backgroundColor: bgColors,
            borderRadius: 3,
            maxBarThickness: 28,
          },
        ],
      },
      options: {
        indexAxis: "y",
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: (ctx) => {
                const v = ctx.raw;
                return options.unit === "ms"
                  ? `${v.toLocaleString()} ms`
                  : `${v.toLocaleString()} req/s`;
              },
            },
          },
        },
        scales: {
          x: {
            type: options.logScale ? "logarithmic" : "linear",
            title: {
              display: true,
              text: options.unit === "ms" ? "Milliseconds" : "Requests / second",
              color: "#94a3b8",
            },
            ticks: { color: "#94a3b8" },
            grid: { color: "rgba(148,163,184,0.1)" },
          },
          y: {
            ticks: {
              color: "#94a3b8",
              font: { size: 11 },
            },
            grid: { display: false },
          },
        },
      },
    });
  }

  // Wait for Chart.js to be available
  function init() {
    if (typeof Chart === "undefined") {
      setTimeout(init, 100);
      return;
    }

    // Set global defaults for dark theme
    Chart.defaults.color = "#94a3b8";

    const jsonHeight = Math.max(350, data.json.length * 22);
    const validateHeight = Math.max(350, data.validate.length * 22);
    const dbHeight = Math.max(350, data.db.length * 22);
    const startupHeight = Math.max(300, data.startup.length * 22);

    document.getElementById("chart-json")?.parentElement?.style.setProperty("height", jsonHeight + "px");
    document.getElementById("chart-validate")?.parentElement?.style.setProperty("height", validateHeight + "px");
    document.getElementById("chart-db")?.parentElement?.style.setProperty("height", dbHeight + "px");
    document.getElementById("chart-startup")?.parentElement?.style.setProperty("height", startupHeight + "px");

    createBarChart("chart-json", data.json, { logScale: true });
    createBarChart("chart-validate", data.validate, { logScale: true });
    createBarChart("chart-db", data.db, { logScale: true });
    createBarChart("chart-startup", data.startup, { logScale: false, unit: "ms" });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>
