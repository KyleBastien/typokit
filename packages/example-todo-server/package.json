{
  "name": "@typokit/example-todo-server",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "test": "rstest run --passWithNoTests",
    "test:contracts": "rstest run --passWithNoTests src/__generated__/",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "generate:openapi": "tsx src/generate-openapi.ts --output ./dist/openapi.json"
  },
  "dependencies": {
    "@typokit/core": "workspace:*",
    "@typokit/errors": "workspace:*",
    "@typokit/example-todo-schema": "workspace:*",
    "@typokit/plugin-debug": "workspace:*",
    "@typokit/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typokit/server-native": "workspace:*",
    "@typokit/testing": "workspace:*",
    "@typokit/platform-node": "workspace:*"
  }
}
