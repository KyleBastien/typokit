{
  "scripts": {
    "test": "rstest run --passWithNoTests",
    "build:native": "napi build --platform --dts src/index.d.ts --js false",
    "build:native:release": "napi build --platform --release --dts src/index.d.ts --js false"
  },
  "name": "@typokit/transform-native",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "version": "0.2.0",
  "type": "module",
  "files": [
    "dist",
    "src",
    "*.node"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@typokit/types": "workspace:*"
  },
  "optionalDependencies": {
    "@typokit/transform-native-win32-x64-msvc": "0.2.0",
    "@typokit/transform-native-darwin-x64": "0.2.0",
    "@typokit/transform-native-darwin-arm64": "0.2.0",
    "@typokit/transform-native-linux-x64-gnu": "0.2.0",
    "@typokit/transform-native-linux-arm64-gnu": "0.2.0",
    "@typokit/transform-native-linux-x64-musl": "0.2.0"
  },
  "napi": {
    "binaryName": "index",
    "package": {
      "name": "@typokit/transform-native"
    },
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/KyleBastien/typokit",
    "directory": "packages/transform-native"
  }
}
