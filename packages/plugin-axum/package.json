{
  "scripts": {
    "test": "rstest run --passWithNoTests",
    "build:native": "napi build --platform --dts src/index.d.ts --js false",
    "build:native:release": "napi build --platform --release --dts src/index.d.ts --js false"
  },
  "name": "@typokit/plugin-axum",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "version": "0.2.2",
  "type": "module",
  "files": [
    "dist",
    "src",
    "*.node"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@typokit/core": "workspace:*",
    "@typokit/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  },
  "napi": {
    "binaryName": "index",
    "package": {
      "name": "@typokit/plugin-axum"
    },
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl"
    ]
  },
  "nx": {
    "targets": {
      "nx-release-publish": {
        "command": "echo Skipped: published via native pipeline"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/KyleBastien/typokit",
    "directory": "packages/plugin-axum"
  },
  "optionalDependencies": {
    "@typokit/plugin-axum-darwin-arm64": "0.2.2",
    "@typokit/plugin-axum-darwin-x64": "0.2.2",
    "@typokit/plugin-axum-linux-arm64-gnu": "0.2.2",
    "@typokit/plugin-axum-linux-x64-gnu": "0.2.2",
    "@typokit/plugin-axum-linux-x64-musl": "0.2.2",
    "@typokit/plugin-axum-win32-x64-msvc": "0.2.2"
  }
}
